@model AdminLoginViewModel
@{
    ViewData["Title"] = "Admin Login";
}

<div class="auth-container">
    <div class="card auth-card fade-in">
        <div class="auth-header">
            <h2>🛡️ Admin Login</h2>
            <p>Access the administration panel</p>
        </div>

        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="Username"></label>
                <input asp-for="Username" class="form-control" placeholder="Admin username" />
                <span asp-validation-for="Username" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password"></label>
                <input asp-for="Password" class="form-control" type="password" placeholder="Admin password" />
                <span asp-validation-for="Password" class="field-validation-error"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-block btn-lg">
                Login as Admin
            </button>
        </form>

        <div class="auth-footer">
            <a asp-controller="Home" asp-action="Index">← Back to Home</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
