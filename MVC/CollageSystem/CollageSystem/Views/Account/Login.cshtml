@model LoginViewModel
@{
    ViewData["Title"] = "Student Login";
}

<div class="auth-container">
    <div class="card auth-card fade-in">
        <div class="auth-header">
            <h2>🔑 Student Login</h2>
            <p>Enter your registration number and password</p>
        </div>

        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="RegistrationNumber"></label>
                <input asp-for="RegistrationNumber" class="form-control" placeholder="e.g. STU-2026-0001" />
                <span asp-validation-for="RegistrationNumber" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password"></label>
                <input asp-for="Password" class="form-control" type="password" placeholder="Your default password" />
                <span asp-validation-for="Password" class="field-validation-error"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-block btn-lg">
                Login
            </button>
        </form>

        <div class="auth-footer">
            <p>Don't have an account? <a asp-controller="Account" asp-action="Register">Register here</a></p>
            <p style="margin-top: var(--space-sm); font-size: 0.8rem; color: var(--text-muted);">
                Default password format: <strong>[Last 4 digits of phone]@@[First Name]</strong>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
