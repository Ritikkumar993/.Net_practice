@model CollegeApplication.Models.Applicant
@{
    ViewData["Title"] = "Edit Application";
}

<div class="ca-container">
    <div>
        <div class="breadcrumb-ca">
            <a asp-controller="Home" asp-action="Index">Home</a>
            <span class="sep">/</span>
            <a asp-controller="Applicant" asp-action="Index">Applicants</a>
            <span class="sep">/</span>
            Edit Application
        </div>
        <div class="page-header">
            <h1 class="page-title">
                Edit Application
                <span class="badge-ca badge-open" style="font-size:var(--text-sm); vertical-align: middle; margin-left: var(--space-3);">
                    REG-@Model.RegistrationNo.ToString("D5")
                </span>
            </h1>
        </div>
    </div>

    <!-- Info Banner -->
    <div class="info-banner">
        <span>ℹ️</span>
        <span>Editing registration <strong>REG-@Model.RegistrationNo.ToString("D5")</strong> — changes will update immediately after saving.</span>
    </div>

    <div class="ca-card form-card-accent" style="max-width: 780px; margin: 0 auto;">
        <div class="ca-card-body">

            <!-- Validation Summary -->
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="validation-summary-ca">
                    <strong>⚠ Please fix the following errors:</strong>
                    <div asp-validation-summary="All"></div>
                </div>
            }

            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="RegistrationNo" />
                <input type="hidden" asp-for="ProfilePhoto" />

                <div class="form-grid-2">

                    <!-- Full Name -->
                    <div class="form-group-ca form-grid-full">
                        <label asp-for="FullName" class="form-label-ca">Full Name</label>
                        <input asp-for="FullName" class="form-input-ca" placeholder="e.g. Rahul Sharma" />
                        <span asp-validation-for="FullName" class="field-error"></span>
                    </div>

                    <!-- Email -->
                    <div class="form-group-ca">
                        <label asp-for="Email" class="form-label-ca">Email Address</label>
                        <input asp-for="Email" type="email" class="form-input-ca" />
                        <span asp-validation-for="Email" class="field-error"></span>
                    </div>

                    <!-- Phone -->
                    <div class="form-group-ca">
                        <label asp-for="PhoneNo" class="form-label-ca">Phone Number</label>
                        <input asp-for="PhoneNo" class="form-input-ca" />
                        <span asp-validation-for="PhoneNo" class="field-error"></span>
                    </div>

                    <!-- Date of Birth -->
                    <div class="form-group-ca">
                        <label asp-for="DateOfBirth" class="form-label-ca">Date of Birth</label>
                        <input asp-for="DateOfBirth" type="date" class="form-input-ca" />
                        <span asp-validation-for="DateOfBirth" class="field-error"></span>
                    </div>

                    <!-- Gender -->
                    <div class="form-group-ca">
                        <label asp-for="Gender" class="form-label-ca">Gender</label>
                        <select asp-for="Gender" class="form-input-ca">
                            <option value="">— Select Gender —</option>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                            <option value="Other">Other</option>
                        </select>
                        <span asp-validation-for="Gender" class="field-error"></span>
                    </div>

                    <!-- Course -->
                    <div class="form-group-ca form-grid-full">
                        <label asp-for="Course" class="form-label-ca">Course</label>
                        <select asp-for="Course" class="form-input-ca">
                            <option value="">— Select Course —</option>
                            <option value="Engineering">Engineering</option>
                            <option value="Medicine">Medicine</option>
                            <option value="Arts">Arts</option>
                            <option value="Commerce">Commerce</option>
                            <option value="Science">Science</option>
                            <option value="Law">Law</option>
                            <option value="Management">Management</option>
                            <option value="Agriculture">Agriculture</option>
                            <option value="Architecture">Architecture</option>
                            <option value="Design">Design</option>
                            <option value="Education">Education</option>
                            <option value="Pharmacy">Pharmacy</option>
                        </select>
                        <span asp-validation-for="Course" class="field-error"></span>
                    </div>

                    <!-- Address -->
                    <div class="form-group-ca form-grid-full">
                        <label asp-for="Address" class="form-label-ca">Address</label>
                        <textarea asp-for="Address" class="form-input-ca" rows="3"></textarea>
                        <span asp-validation-for="Address" class="field-error"></span>
                    </div>

                    <!-- Photo Section -->
                    <div class="form-group-ca form-grid-full">
                        <label class="form-label-ca">Profile Photo</label>

                        @if (!string.IsNullOrEmpty(Model.ProfilePhoto))
                        {
                            <div class="photo-thumb-box">
                                <img src="@Model.ProfilePhoto" alt="Current photo" />
                                <div>
                                    <div class="thumb-label">Current Photo</div>
                                    <div class="thumb-sub">Upload a new file below to replace it</div>
                                </div>
                            </div>
                        }

                        <div class="photo-upload-zone" id="uploadZone">
                            <input asp-for="PhotoFile" type="file" accept=".jpg,.jpeg,.png" id="photoInput" />
                            <div class="upload-icon">📷</div>
                            <div class="upload-title">
                                @(string.IsNullOrEmpty(Model.ProfilePhoto) ? "Click to upload or drag & drop" : "Replace Photo")
                            </div>
                            <div class="upload-subtitle">JPG, JPEG or PNG — max 2 MB</div>
                        </div>

                        <div id="photo-preview">
                            <img src="" alt="Preview" id="previewImg" />
                            <div class="preview-info">
                                <div class="preview-name" id="previewName"></div>
                                <div class="preview-size" id="previewSz"></div>
                            </div>
                        </div>
                        <span asp-validation-for="PhotoFile" class="field-error">⚠ <span></span></span>
                    </div>
                </div>

                <!-- Form Footer -->
                <div style="display:flex; justify-content:flex-end; gap: var(--space-3); margin-top: var(--space-6); padding-top: var(--space-6); border-top: 1px solid var(--color-border);">
                    <a asp-action="Index" class="btn-secondary-ca">Cancel</a>
                    <button type="submit" class="btn-primary-ca" onclick="this.classList.add('btn-submitting')">
                        <span class="spinner"></span>
                        <span class="btn-text">💾 Save Changes</span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        var photoInput = document.getElementById('photoInput');
        var previewBox = document.getElementById('photo-preview');
        var previewImg = document.getElementById('previewImg');
        var previewName = document.getElementById('previewName');
        var previewSz   = document.getElementById('previewSz');
        var uploadZone  = document.getElementById('uploadZone');

        photoInput?.addEventListener('change', function () {
            var file = this.files[0];
            if (!file) return;
            if (!['image/jpeg','image/png'].includes(file.type)) { alert('Only JPG and PNG allowed.'); this.value=''; return; }
            if (file.size > 2*1024*1024) { alert('File must be smaller than 2 MB.'); this.value=''; return; }
            var reader = new FileReader();
            reader.onload = function(e) {
                previewImg.src = e.target.result;
                previewName.textContent = file.name;
                previewSz.textContent = (file.size/1024).toFixed(1)+' KB';
                previewBox.style.display = 'flex';
            };
            reader.readAsDataURL(file);
        });

        uploadZone?.addEventListener('dragover', function(e){ e.preventDefault(); this.classList.add('drag-over'); });
        uploadZone?.addEventListener('dragleave', function(){ this.classList.remove('drag-over'); });
        uploadZone?.addEventListener('drop', function(e){
            e.preventDefault(); this.classList.remove('drag-over');
            if (e.dataTransfer.files.length) { photoInput.files = e.dataTransfer.files; photoInput.dispatchEvent(new Event('change')); }
        });
    </script>
}