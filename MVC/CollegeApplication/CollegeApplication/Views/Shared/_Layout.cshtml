<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="CollegeApply — Manage college admission applications with ease." />
    <title>@ViewData["Title"] — CollegeApply</title>
    <script type="importmap"></script>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&family=DM+Sans:wght@400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <!-- Bootstrap (used selectively) -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Custom Design System -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <!-- ── Navbar ── -->
    <header class="ca-navbar">
        <a class="brand" asp-area="" asp-controller="Home" asp-action="Index">
            <div class="brand-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
                    <path d="M6 12v5c3 3 9 3 12 0v-5"/>
                </svg>
            </div>
            CollegeApply
        </a>
        <span class="nav-spacer"></span>
        <button class="navbar-toggler-ca" id="navToggle" aria-label="Toggle navigation">&#9776;</button>
        <nav id="mainNav">
            <a class="ca-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
               asp-area="" asp-controller="Home" asp-action="Index">Home</a>
            <a class="ca-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Applicant" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
               asp-area="" asp-controller="Applicant" asp-action="Index">All Applicants</a>
            <a class="ca-nav-btn"
               asp-area="" asp-controller="Applicant" asp-action="Create">
                ＋ New Application
            </a>
        </nav>
    </header>

    <!-- ── TempData Success Banner ── -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="success-banner" id="successBanner">
            <span class="banner-icon">✓</span>
            <span>@TempData["SuccessMessage"]</span>
            <button class="banner-close" id="bannerClose" aria-label="Dismiss">✕</button>
        </div>
    }

    <!-- ── Main Content ── -->
    <main role="main" class="page-content">
        @RenderBody()
    </main>

    <!-- ── Footer ── -->
    <footer class="ca-footer">
        © 2025 College Application System — Built with ASP.NET Core MVC
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // ── Mobile nav toggle ──
        document.getElementById('navToggle')?.addEventListener('click', function () {
            document.getElementById('mainNav').classList.toggle('open');
        });

        // ── Auto-dismiss success banner ──
        (function () {
            var banner = document.getElementById('successBanner');
            var close  = document.getElementById('bannerClose');
            if (!banner) return;

            function hideBanner() {
                banner.classList.add('hiding');
                setTimeout(function () { banner.style.display = 'none'; }, 400);
            }

            if (close) close.addEventListener('click', hideBanner);
            setTimeout(hideBanner, 6000);
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
