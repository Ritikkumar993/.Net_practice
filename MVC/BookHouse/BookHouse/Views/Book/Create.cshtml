@model BookHouse.Models.Book

<h2>Add Book</h2>

<form asp-action="Create" method="post">

    <div>
        <label>Book Title</label>
        <input asp-for="Title" />
    </div>

    <br />

    <div>
        <label>Author</label>

        <select asp-for="AuthorId"
                asp-items="ViewBag.Authors">
        </select>

    </div>

    <br />

    <button type="submit">Save</button>

</form>

<br />

<a asp-action="Index">Back</a>