@* @model IEnumerable<mvcStudentProj.Models.Student> *@
@model IEnumerable<mvcStudentProj.Models.StudentDetails>

<h2>Students List</h2>

<table border="1" cellpadding="8">
    <tr>
        
        <th>Name</th>
        <th>Age Squared</th>
    
    </tr>

    @foreach (var s in Model)
    {
        <tr>
           
            <td>@s.Name</td>
            <td>@s.AgeSquared</td>
           
        </tr>
    }
</table>