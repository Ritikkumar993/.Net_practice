@model EmployeeManagement.Models.Employee
@{
    Layout = null; // standalone print page
    string formattedSalary = Model.Salary.ToString("N0");
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <title>@Model.FullName — EmpTrack Profile</title>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap"
        rel="stylesheet" />
    <style>
        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', sans-serif;
            font-size: 13px;
            color: #111827;
            background: #fff;
            padding: 40px;
        }

        .header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 2px solid #1B3A6B;
            padding-bottom: 16px;
            margin-bottom: 24px;
        }

        .logo {
            font-size: 20px;
            font-weight: 700;
            color: #1B3A6B;
        }

        .emp-id {
            font-family: 'IBM Plex Mono', monospace;
            font-size: 12px;
            color: #6B7280;
        }

        .profile-top {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-bottom: 24px;
        }

        .avatar {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            background: #1B3A6B;
            color: white;
            font-size: 24px;
            font-weight: 700;
            display: grid;
            place-items: center;
            overflow: hidden;
            flex-shrink: 0;
        }

        .avatar img {
            width: 72px;
            height: 72px;
            object-fit: cover;
            border-radius: 50%;
        }

        .name {
            font-size: 22px;
            font-weight: 700;
        }

        .designation {
            font-size: 14px;
            color: #4B5563;
            margin-top: 2px;
        }

        .badge {
            background: #EBF0FB;
            color: #1B3A6B;
            border-radius: 20px;
            padding: 3px 10px;
            font-size: 11px;
            font-weight: 600;
            display: inline-block;
            margin-top: 6px;
            margin-right: 6px;
        }

        .badge-green {
            background: #D1FAE5;
            color: #065F46;
        }

        .badge-amber {
            background: #FEF3C7;
            color: #92400E;
        }

        .badge-blue {
            background: #E0F2FE;
            color: #075985;
        }

        .badge-purple {
            background: #F3E8FF;
            color: #6B21A8;
        }

        .section-title {
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #9CA3AF;
            border-bottom: 1px solid #E2E5F0;
            padding-bottom: 6px;
            margin: 20px 0 12px;
        }

        .info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px 24px;
        }

        .info-label {
            font-size: 10px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: #9CA3AF;
            margin-bottom: 2px;
        }

        .info-value {
            font-size: 13px;
            font-weight: 500;
            color: #111827;
        }

        .mono {
            font-family: 'IBM Plex Mono', monospace;
        }

        .salary {
            font-size: 18px;
            font-weight: 700;
            color: #1B3A6B;
            font-family: 'IBM Plex Mono', monospace;
        }

        .footer {
            margin-top: 32px;
            padding-top: 12px;
            border-top: 1px solid #E2E5F0;
            text-align: center;
            font-size: 11px;
            color: #9CA3AF;
        }

        @@media print {
            body {
                padding: 20px;
            }

            .no-print {
                display: none;
            }
        }
    </style>
</head>

<body>
    <div class="header">
        <div class="logo">EmpTrack</div>
        <div class="emp-id">Generated: @DateTime.Now.ToString("dd MMM yyyy HH:mm")</div>
    </div>
    <div class="profile-top">
        <div class="avatar">
            @if (!string.IsNullOrEmpty(Model.ProfilePhotoPath))
            {
                <img src="@Model.ProfilePhotoPath" alt="" />
            }
            else
            {
                @Model.AvatarInitials
            }
        </div>
        <div>
            <div class="name">@Model.FullName</div>
            <div class="designation">@Model.Designation · @Model.Department</div>
            @{
                var bc = Model.EmploymentType switch
                {
                    "Full-Time" => "badge-green",
                    "Contract" => "badge-amber",
                    "Intern"
                    => "badge-blue",
                    "Part-Time" => "badge-purple",
                    _ => ""
                };
            }
            <span class="badge @bc">@Model.EmploymentType</span>
            <span class="badge @(Model.IsActive ? "badge-green" : "")">@(Model.IsActive ? "Active" : "Inactive")</span>
        </div>
    </div>
    <div class="section-title">Personal Information</div>
    <div class="info-grid">
        <div>
            <div class="info-label">Full Name</div>
            <div class="info-value">@Model.FullName</div>
        </div>
        <div>
            <div class="info-label">Gender</div>
            <div class="info-value">@Model.Gender</div>
        </div>
        <div>
            <div class="info-label">Email</div>
            <div class="info-value">@Model.Email</div>
        </div>
        <div>
            <div class="info-label">Phone</div>
            <div class="info-value mono">@Model.PhoneNumber</div>
        </div>
        <div>
            <div class="info-label">Date of Birth</div>
            <div class="info-value">@Model.DateOfBirth.ToString("dd MMMM yyyy")</div>
        </div>
        <div>
            <div class="info-label">Aadhaar</div>
            <div class="info-value mono">@Model.MaskedAadhaar</div>
        </div>
        <div style="grid-column:1/-1;">
            <div class="info-label">Address</div>
            <div class="info-value">@(string.IsNullOrEmpty(Model.Address) ? "—" : Model.Address)</div>
        </div>
    </div>
    <div class="section-title">Employment Details</div>
    <div class="info-grid">
        <div>
            <div class="info-label">Employee ID</div>
            <div class="info-value mono">@Model.EmployeeCode</div>
        </div>
        <div>
            <div class="info-label">Department</div>
            <div class="info-value">@Model.Department</div>
        </div>
        <div>
            <div class="info-label">Designation</div>
            <div class="info-value">@Model.Designation</div>
        </div>
        <div>
            <div class="info-label">Employment Type</div>
            <div class="info-value">@Model.EmploymentType</div>
        </div>
        <div>
            <div class="info-label">Date of Joining</div>
            <div class="info-value">@Model.DateOfJoining.ToString("dd MMMM yyyy")</div>
        </div>
        <div>
            <div class="info-label">Tenure</div>
            <div class="info-value">@Model.Tenure</div>
        </div>
        <div>
            <div class="info-label">Salary</div>
            <div class="salary">₹@formattedSalary / month</div>
        </div>
        <div>
            <div class="info-label">Status</div>
            <div class="info-value">@(Model.IsActive ? "Active" : "Inactive")</div>
        </div>
    </div>
    <div class="section-title">Emergency Contact</div>
    <div class="info-grid">
        <div>
            <div class="info-label">Name</div>
            <div class="info-value">@Model.EmergencyContactName</div>
        </div>
        <div>
            <div class="info-label">Phone</div>
            <div class="info-value mono">@Model.EmergencyContactPhone</div>
        </div>
    </div>
    @if (Model.DocumentPaths.Any())
    {
        <div class="section-title">Uploaded Documents</div>
        <div>@string.Join(", ", Model.DocumentPaths.Select(p => p.Replace('\\', '/').Split('/').LastOrDefault() ?? p))</div>
    }
    <div class="footer">EmpTrack Employee Management System · Confidential · @DateTime.Now.Year</div>
    <div class="no-print" style="text-align:center;margin-top:24px;">
        <button onclick="window.print()"
            style="background:#1B3A6B;color:white;border:none;border-radius:7px;padding:10px 24px;font-size:13px;font-weight:600;cursor:pointer;">🖨
            Print / Save as PDF</button>
    </div>
</body>

</html>
