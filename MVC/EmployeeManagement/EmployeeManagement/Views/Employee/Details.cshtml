@model EmployeeManagement.Models.Employee
@{
    ViewData["Title"] = Model.FullName;
    ViewData["Breadcrumb"] = $"<a href='/'>Dashboard</a><span class='breadcrumb-sep'>/</span><a href='/Employee'>Employees</a><span class='breadcrumb-sep'>/</span><span class='breadcrumb-current'>{Model.FullName}</span>";
    var typeBadge = Model.EmploymentType switch {
        "Full-Time" => "badge-fulltime",
        "Contract"  => "badge-contract",
        "Intern"    => "badge-intern",
        "Part-Time" => "badge-parttime",
        _ => "badge-dept"
    };
    string formattedSalary = Model.Salary.ToString("N0");
}

<div class="details-layout">
    <!-- Left: Profile Card -->
    <div class="profile-card">
        <div class="profile-avatar-lg">
            @if (!string.IsNullOrEmpty(Model.ProfilePhotoPath))
            {
                <img src="@Model.ProfilePhotoPath" alt="@Model.FullName" />
            }
            else
            {
                @Model.AvatarInitials
            }
        </div>
        <div>
            <div class="profile-name">@Model.FullName</div>
            <div class="profile-designation">@Model.Designation</div>
        </div>
        <div class="profile-badges">
            <span class="badge badge-dept">@Model.Department</span>
            <span class="badge @typeBadge">@Model.EmploymentType</span>
            <span class="badge @(Model.IsActive ? "badge-active" : "badge-inactive")">@(Model.IsActive ? "● Active" : "● Inactive")</span>
        </div>
        <div style="width:100%;border-top:1px solid var(--color-border);padding-top:var(--space-4);">
            <div style="font-size:var(--text-xs);color:var(--color-text-muted);text-transform:uppercase;letter-spacing:0.07em;margin-bottom:var(--space-3);">Employee Info</div>
            <div style="display:flex;flex-direction:column;gap:var(--space-2);">
                <div style="display:flex;justify-content:space-between;font-size:var(--text-xs);">
                    <span style="color:var(--color-text-muted);">Emp ID</span>
                    <span class="mono" style="color:var(--color-text-primary);font-weight:600;">@Model.EmployeeCode</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:var(--text-xs);">
                    <span style="color:var(--color-text-muted);">Tenure</span>
                    <span style="color:var(--color-text-primary);font-weight:600;">@Model.Tenure</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:var(--text-xs);">
                    <span style="color:var(--color-text-muted);">Age</span>
                    <span style="color:var(--color-text-primary);font-weight:600;">@Model.Age years</span>
                </div>
            </div>
        </div>
        <div class="profile-actions">
            <a asp-action="DownloadPdf" asp-route-id="@Model.Id" class="btn-primary" target="_blank">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Download PDF
            </a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-secondary">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                Edit Profile
            </a>
        </div>
    </div>

    <!-- Right: Tabbed Content -->
    <div class="tabs-wrapper">
        <div class="tab-list" role="tablist">
            <button class="tab-btn active" data-tab="personal" role="tab">Personal Info</button>
            <button class="tab-btn" data-tab="employment" role="tab">Employment</button>
            <button class="tab-btn" data-tab="documents" role="tab">Documents (@Model.DocumentPaths.Count)</button>
        </div>

        <!-- Personal Info Tab -->
        <div class="tab-panel active" id="tab-personal" role="tabpanel">
            <div class="info-grid">
                <div class="info-field">
                    <label>Full Name</label>
                    <div class="info-value">@Model.FullName</div>
                </div>
                <div class="info-field">
                    <label>Gender</label>
                    <div class="info-value">@Model.Gender</div>
                </div>
                <div class="info-field">
                    <label>Email</label>
                    <div class="info-value" style="word-break:break-all;">@Model.Email</div>
                </div>
                <div class="info-field">
                    <label>Phone</label>
                    <div class="info-value" style="font-family:var(--font-mono);">@Model.PhoneNumber</div>
                </div>
                <div class="info-field">
                    <label>Date of Birth</label>
                    <div class="info-value">@Model.DateOfBirth.ToString("dd MMMM yyyy") (@Model.Age years)</div>
                </div>
                <div class="info-field">
                    <label>Aadhaar Number</label>
                    <div class="info-value" style="display:flex;align-items:center;gap:var(--space-2);">
                        <span id="aadhaarMasked" style="font-family:var(--font-mono);">@Model.MaskedAadhaar</span>
                        <span id="aadhaarFull" style="display:none;font-family:var(--font-mono);">@Model.AadhaarNumber</span>
                        <button type="button" id="aadhaarReveal" class="btn-icon" style="width:26px;height:26px;" title="Reveal Aadhaar">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        </button>
                    </div>
                </div>
                <div class="info-field" style="grid-column:1/-1;">
                    <label>Address</label>
                    <div class="info-value" style="line-height:1.6;">@(string.IsNullOrEmpty(Model.Address) ? "—" : Model.Address)</div>
                </div>
                <div class="info-field">
                    <label>Emergency Contact</label>
                    <div class="info-value">@Model.EmergencyContactName</div>
                </div>
                <div class="info-field">
                    <label>Emergency Phone</label>
                    <div class="info-value" style="font-family:var(--font-mono);">@Model.EmergencyContactPhone</div>
                </div>
            </div>
        </div>

        <!-- Employment Tab -->
        <div class="tab-panel" id="tab-employment" role="tabpanel">
            <div class="info-grid">
                <div class="info-field">
                    <label>Department</label>
                    <div class="info-value"><span class="badge badge-dept">@Model.Department</span></div>
                </div>
                <div class="info-field">
                    <label>Designation</label>
                    <div class="info-value">@Model.Designation</div>
                </div>
                <div class="info-field">
                    <label>Employment Type</label>
                    <div class="info-value"><span class="badge @typeBadge">@Model.EmploymentType</span></div>
                </div>
                <div class="info-field">
                    <label>Date of Joining</label>
                    <div class="info-value">@Model.DateOfJoining.ToString("dd MMMM yyyy")</div>
                </div>
                <div class="info-field">
                    <label>Salary</label>
                    <div class="info-value" style="font-family:var(--font-mono);font-size:var(--text-lg);color:var(--color-primary);font-weight:700;">₹@formattedSalary</div>
                </div>
                <div class="info-field">
                    <label>Tenure</label>
                    <div class="info-value" style="font-weight:600;color:var(--color-accent);">@Model.Tenure</div>
                </div>
                <div class="info-field">
                    <label>Status</label>
                    <div class="info-value"><span class="badge @(Model.IsActive ? "badge-active" : "badge-inactive")">@(Model.IsActive ? "Active" : "Inactive")</span></div>
                </div>
                <div class="info-field">
                    <label>Employee ID</label>
                    <div class="info-value mono">@Model.EmployeeCode</div>
                </div>
            </div>
        </div>

        <!-- Documents Tab -->
        <div class="tab-panel" id="tab-documents" role="tabpanel">
            @if (Model.DocumentPaths.Any())
            {
                <div class="doc-list">
                    @foreach (var docPath in Model.DocumentPaths)
                    {
                        string fileName = docPath.Replace('\\', '/').Split('/').LastOrDefault() ?? docPath;
                        string ext = fileName.Contains('.') ? "." + fileName.Split('.').Last().ToLower() : "";
                        <div class="doc-card">
                            <div class="doc-icon">
                                @if (ext == ".pdf")
                                {
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                                }
                                else
                                {
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                                }
                            </div>
                            <div class="doc-name">@fileName</div>
                            <a href="@docPath" target="_blank" class="btn-icon" title="Download">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                            </a>
                        </div>
                    }
                </div>
            }
            else
            {
                <div style="text-align:center;padding:var(--space-10);color:var(--color-text-muted);">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" style="margin:0 auto var(--space-3);opacity:0.4;"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    <div style="font-size:var(--text-sm);font-weight:500;">No documents uploaded</div>
                    <div style="font-size:var(--text-xs);margin-top:4px;"><a asp-action="Edit" asp-route-id="@Model.Id" style="color:var(--color-primary);">Edit profile</a> to add documents.</div>
                </div>
            }
        </div>
    </div>
</div>
