@model EmployeeManagement.Models.Employee
@{
    ViewData["Title"] = "Add Employee";
    ViewData["Breadcrumb"] = "<a href='/'>Dashboard</a><span class='breadcrumb-sep'>/</span><a href='/Employee'>Employees</a><span class='breadcrumb-sep'>/</span><span class='breadcrumb-current'>Add New</span>";
    var departments = (List<string>?)ViewBag.Departments ?? new List<string>();
    var departmentOptions = departments.Any() ? departments : new List<string> { "Engineering", "HR", "Finance", "Marketing", "Operations", "Sales" };
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Register New Employee</h1>
        <p>Fill in the details to add a new team member to the directory.</p>
    </div>
</div>

<form asp-action="Create" method="post" enctype="multipart/form-data" data-spinner>
    <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
    <div class="card" style="max-width:880px;margin:0 auto;">
        <div class="card-body">

            <!-- Section 1: Personal Information -->
            <div class="form-section">
                <div class="form-section-header">Personal Information</div>
                <div class="form-grid full">
                    <div class="form-group">
                        <label class="form-label" asp-for="FullName">Full Name <span class="required-star">*</span></label>
                        <input class="form-input" asp-for="FullName" placeholder="e.g. Arjun Sharma" />
                        <span asp-validation-for="FullName" class="field-validation-error"></span>
                    </div>
                </div>
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label" asp-for="Email">Email Address <span class="required-star">*</span></label>
                        <input class="form-input" asp-for="Email" type="email" placeholder="arjun@company.com" />
                        <span asp-validation-for="Email" class="field-validation-error"></span>
                    </div>
                    <div class="form-group">
                        <label class="form-label" asp-for="PhoneNumber">Phone Number <span class="required-star">*</span></label>
                        <input class="form-input" asp-for="PhoneNumber" placeholder="10-digit number starting 6–9" maxlength="10" />
                        <span asp-validation-for="PhoneNumber" class="field-validation-error"></span>
                    </div>
                </div>
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label" asp-for="DateOfBirth">Date of Birth <span class="required-star">*</span></label>
                        <input class="form-input" asp-for="DateOfBirth" type="date" max="@DateTime.Today.AddYears(-18).ToString("yyyy-MM-dd")" />
                        <span asp-validation-for="DateOfBirth" class="field-validation-error"></span>
                    </div>
                    <div class="form-group">
                        <label class="form-label" asp-for="Gender">Gender <span class="required-star">*</span></label>
                        <select class="form-select" asp-for="Gender">
                            <option value="">Select gender</option>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                            <option value="Non-Binary">Non-Binary</option>
                            <option value="Prefer not to say">Prefer not to say</option>
                        </select>
                        <span asp-validation-for="Gender" class="field-validation-error"></span>
                    </div>
                </div>
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label" asp-for="AadhaarNumber">Aadhaar Card Number <span class="required-star">*</span></label>
                        <div class="input-with-icon" style="position:relative;">
                            <input class="form-input aadhaar-input" asp-for="AadhaarNumber" id="aadhaarInput"
                                   type="password" placeholder="123456789012" maxlength="12" autocomplete="off" />
                            <button type="button" class="input-eye-toggle" id="aadhaarToggle" title="Show/hide Aadhaar">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                            </button>
                        </div>
                        <span asp-validation-for="AadhaarNumber" class="field-validation-error"></span>
                    </div>
                    <div class="form-group"></div>
                </div>
                <div class="form-grid full">
                    <div class="form-group">
                        <label class="form-label" asp-for="Address">Address</label>
                        <textarea class="form-textarea" asp-for="Address" rows="3"
                                  placeholder="Full address (max 500 characters)" maxlength="500"></textarea>
                        <span asp-validation-for="Address" class="field-validation-error"></span>
                    </div>
                </div>
            </div>

            <!-- Section 2: Employment Details -->
            <div class="form-section">
                <div class="form-section-header">Employment Details</div>
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label" asp-for="Department">Department <span class="required-star">*</span></label>
                        <select class="form-select" asp-for="Department">
                            <option value="">Select department</option>
                            @foreach (var d in departmentOptions)
                            {
                                <option value="@d">@d</option>
                            }
                            <option value="Other">Other</option>
                        </select>
                        <span asp-validation-for="Department" class="field-validation-error"></span>
                    </div>
                    <div class="form-group">
                        <label class="form-label" asp-for="Designation">Designation / Job Title <span class="required-star">*</span></label>
                        <input class="form-input" asp-for="Designation" placeholder="e.g. Senior Engineer" />
                        <span asp-validation-for="Designation" class="field-validation-error"></span>
                    </div>
                </div>
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label" asp-for="EmploymentType">Employment Type <span class="required-star">*</span></label>
                        <select class="form-select" asp-for="EmploymentType">
                            <option value="">Select type</option>
                            <option value="Full-Time">Full-Time</option>
                            <option value="Part-Time">Part-Time</option>
                            <option value="Contract">Contract</option>
                            <option value="Intern">Intern</option>
                        </select>
                        <span asp-validation-for="EmploymentType" class="field-validation-error"></span>
                    </div>
                    <div class="form-group">
                        <label class="form-label" asp-for="DateOfJoining">Date of Joining <span class="required-star">*</span></label>
                        <input class="form-input" asp-for="DateOfJoining" type="date" />
                        <span asp-validation-for="DateOfJoining" class="field-validation-error"></span>
                    </div>
                </div>
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label" asp-for="Salary">Salary (₹) <span class="required-star">*</span></label>
                        <div class="input-with-icon">
                            <span class="input-icon-left">₹</span>
                            <input class="form-input" asp-for="Salary" type="number" min="0" step="100" placeholder="50000" />
                        </div>
                        <span asp-validation-for="Salary" class="field-validation-error"></span>
                    </div>
                    <div class="form-group">
                        <label class="form-label" asp-for="IsActive">Employment Status</label>
                        <select class="form-select" asp-for="IsActive">
                            <option value="true">Active</option>
                            <option value="false">Inactive</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- Section 3: Emergency Contact -->
            <div class="form-section">
                <div class="form-section-header">Emergency Contact</div>
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label" asp-for="EmergencyContactName">Contact Name <span class="required-star">*</span></label>
                        <input class="form-input" asp-for="EmergencyContactName" placeholder="e.g. Priya Sharma" />
                        <span asp-validation-for="EmergencyContactName" class="field-validation-error"></span>
                    </div>
                    <div class="form-group">
                        <label class="form-label" asp-for="EmergencyContactPhone">Contact Phone <span class="required-star">*</span></label>
                        <input class="form-input" asp-for="EmergencyContactPhone" placeholder="10-digit number" maxlength="10" />
                        <span asp-validation-for="EmergencyContactPhone" class="field-validation-error"></span>
                    </div>
                </div>
            </div>

            <!-- Section 4: Documents & Photo -->
            <div class="form-section">
                <div class="form-section-header">Documents &amp; Photo</div>
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label">Profile Photo <span style="color:var(--color-text-muted);font-weight:400;">(Optional, max 2MB)</span></label>
                        <div class="upload-zone" id="photoDropZone">
                            <input type="file" id="profilePhotoInput" name="profilePhoto" accept=".jpg,.jpeg,.png" />
                            <div class="upload-zone-icon">
                                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                            </div>
                            <p>Click or drag photo here</p>
                            <span>JPG, JPEG, PNG · Max 2MB</span>
                        </div>
                        <div class="photo-preview-wrap" id="photoPreviewWrap">
                            <img class="photo-preview" id="photoPreview" src="" alt="Preview" />
                            <span style="font-size:var(--text-sm);color:var(--color-text-muted);">Photo selected</span>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Supporting Documents <span style="color:var(--color-text-muted);font-weight:400;">(Optional, max 5MB each)</span></label>
                        <div class="upload-zone" id="docDropZone">
                            <input type="file" id="documentsInput" name="documents" accept=".pdf,.jpg,.jpeg" multiple />
                            <div class="upload-zone-icon">
                                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>
                            </div>
                            <p>Click or drag documents here</p>
                            <span>PDF, JPG · Max 5MB each · Multiple allowed</span>
                        </div>
                        <div class="file-list" id="docList"></div>
                    </div>
                </div>
            </div>

            <!-- Form Footer -->
            <div class="form-footer">
                <a asp-action="Index" class="btn-secondary">Cancel</a>
                <button type="submit" class="btn-primary" data-spinner-btn>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v14a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                    Save Employee
                </button>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
