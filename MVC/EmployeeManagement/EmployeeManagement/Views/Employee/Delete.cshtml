@model EmployeeManagement.Models.Employee
@{
    ViewData["Title"] = "Delete Employee";
    ViewData["Breadcrumb"] = $"<a href='/'>Dashboard</a><span class='breadcrumb-sep'>/</span><a href='/Employee'>Employees</a><span class='breadcrumb-sep'>/</span><span class='breadcrumb-current'>Delete</span>";
}

<div class="delete-card">
    <div class="delete-icon">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="3 6 5 6 21 6"/>
            <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
            <path d="M10 11v6"/><path d="M14 11v6"/>
            <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
        </svg>
    </div>
    <h1 class="delete-title">Delete Employee Record?</h1>
    <p class="delete-body">
        You are about to permanently delete <strong>@Model.FullName</strong> (@Model.EmployeeCode).
        All associated data including documents will be removed. <strong>This cannot be undone.</strong>
    </p>

    <!-- Employee snapshot -->
    <div class="delete-snapshot">
        <div class="emp-avatar" style="width:48px;height:48px;background:#1B3A6B;color:white;font-size:var(--text-sm);font-weight:700;border-radius:50%;display:grid;place-items:center;flex-shrink:0;">
            @if (!string.IsNullOrEmpty(Model.ProfilePhotoPath))
            {
                <img src="@Model.ProfilePhotoPath" alt="@Model.FullName" style="width:48px;height:48px;border-radius:50%;object-fit:cover;" />
            }
            else
            {
                @Model.AvatarInitials
            }
        </div>
        <div style="text-align:left;">
            <div style="font-weight:700;color:var(--color-text-primary);">@Model.FullName</div>
            <div style="font-size:var(--text-xs);color:var(--color-text-muted);margin-top:2px;">@Model.Designation &nbsp;·&nbsp; @Model.Department</div>
            <div style="font-size:var(--text-xs);color:var(--color-text-muted);font-family:var(--font-mono);">@Model.EmployeeCode</div>
        </div>
    </div>

    <div class="delete-actions">
        <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-danger" style="justify-content:center;width:100%;padding:13px 20px;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                Yes, Permanently Delete
            </button>
        </form>
        <a asp-action="Index" class="btn-secondary" style="justify-content:center;padding:13px 20px;">
            No, Keep Record
        </a>
    </div>
</div>
