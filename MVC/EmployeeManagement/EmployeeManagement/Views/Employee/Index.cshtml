@model List<EmployeeManagement.Models.Employee>
@{
    ViewData["Title"] = "All Employees";
    ViewData["Breadcrumb"] = "<a href='/'>Dashboard</a><span class='breadcrumb-sep'>/</span><span class='breadcrumb-current'>Employees</span>";
    var departments = (List<string>?)ViewBag.Departments ?? new List<string>();
    string? q = ViewBag.Query;
    string? dept = ViewBag.Department;
    string? empType = ViewBag.EmploymentType;
    int? joiningYear = ViewBag.JoiningYear;
    int totalCount = (int)(ViewBag.TotalCount ?? Model.Count);
    var employmentTypes = new[] { "Full-Time", "Part-Time", "Contract", "Intern" };
    var joiningYears = Enumerable.Range(2015, DateTime.Today.Year - 2015 + 1).Reverse();
}

<div class="page-header">
    <div class="page-header-left">
        <h1>All Employees <span class="badge badge-count">@Model.Count</span></h1>
        <p>Showing @Model.Count of @totalCount total employees</p>
    </div>
    <div class="page-header-right">
        <div class="export-wrapper">
            <button class="btn-export" id="exportBtn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Export
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="export-dropdown" id="exportDropdown">
                <a asp-controller="Employee" asp-action="ExportCsv">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    Download All (CSV)
                </a>
                <a asp-controller="Employee" asp-action="ExportExcel">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
                    Download All (Excel)
                </a>
                @if (!string.IsNullOrEmpty(q) || !string.IsNullOrEmpty(dept) || !string.IsNullOrEmpty(empType) || joiningYear.HasValue)
                {
                    <a asp-controller="Employee" asp-action="ExportCsv" asp-route-q="@q" asp-route-department="@dept" asp-route-employmentType="@empType" asp-route-joiningYear="@joiningYear">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                        Download Filtered (CSV)
                    </a>
                    <a asp-controller="Employee" asp-action="ExportExcel" asp-route-q="@q" asp-route-department="@dept" asp-route-employmentType="@empType" asp-route-joiningYear="@joiningYear">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                        Download Filtered (Excel)
                    </a>
                }
            </div>
        </div>
        <a asp-controller="Employee" asp-action="Create" class="btn-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Add Employee
        </a>
    </div>
</div>

<!-- Filter Bar -->
<form method="get" asp-action="Index">
    <div class="filter-card">
        <div class="filter-row">
            <div class="form-group search-group">
                <label class="form-label">Search</label>
                <div class="input-with-icon">
                    <span class="input-icon-left">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                    </span>
                    <input class="form-input" name="q" value="@q" placeholder="Search by name, email, Emp ID…" />
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">Department</label>
                <select class="form-select" name="department">
                    <option value="">All Departments</option>
                    @foreach (var d in departments)
                    {
                        <option value="@d" selected="@(dept == d ? "selected" : null)">@d</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Employment Type</label>
                <select class="form-select" name="employmentType">
                    <option value="">All Types</option>
                    @foreach (var et in employmentTypes)
                    {
                        <option value="@et" selected="@(empType == et ? "selected" : null)">@et</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Joining Year</label>
                <select class="form-select" name="joiningYear">
                    <option value="">Any Year</option>
                    @foreach (var yr in joiningYears)
                    {
                        <option value="@yr" selected="@(joiningYear == yr ? "selected" : null)">@yr</option>
                    }
                </select>
            </div>
            <div class="form-group" style="flex:0;align-self:flex-end;display:flex;gap:var(--space-2);">
                <button type="submit" class="btn-primary">Apply</button>
                <a asp-action="Index" class="btn-secondary">Reset</a>
            </div>
        </div>
    </div>
</form>

<!-- Bulk Action Bar -->
<div class="bulk-action-bar" id="bulkActionBar">
    <span><strong id="selectedCount">0</strong> selected</span>
    <a asp-controller="Employee" asp-action="ExportCsv" class="btn-secondary" style="font-size:var(--text-xs);padding:5px 12px;">Download Selected (CSV)</a>
    <button class="btn-secondary" style="font-size:var(--text-xs);padding:5px 12px;color:var(--color-danger);border-color:var(--color-danger);">Delete Selected</button>
</div>

<!-- Table Card -->
<div class="table-card">
    <div class="table-responsive">
        <table class="data-table">
            <thead>
                <tr>
                    <th style="width:40px;"><input type="checkbox" id="selectAll" style="cursor:pointer;" /></th>
                    <th>Emp ID</th>
                    <th>Employee</th>
                    <th>Department</th>
                    <th>Designation</th>
                    <th>Type</th>
                    <th>Joined</th>
                    <th>Phone</th>
                    <th style="width:140px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    var avatarColors = new[] { "#1B3A6B","#0EA271","#D97706","#0284C7","#7C3AED","#DC2626","#059669","#2452A0" };
                    foreach (var emp in Model)
                    {
                        var typeBadge = emp.EmploymentType switch {
                            "Full-Time" => "badge-fulltime",
                            "Contract"  => "badge-contract",
                            "Intern"    => "badge-intern",
                            "Part-Time" => "badge-parttime",
                            _ => "badge-dept"
                        };
                        <tr>
                            <td><input type="checkbox" class="row-checkbox" value="@emp.Id" style="cursor:pointer;" /></td>
                            <td><span class="mono">@emp.EmployeeCode</span></td>
                            <td>
                                <div class="emp-cell">
                                    <div class="emp-avatar" style="background:@avatarColors[emp.Id % avatarColors.Length]">
                                        @if (!string.IsNullOrEmpty(emp.ProfilePhotoPath))
                                        {
                                            <img src="@emp.ProfilePhotoPath" alt="@emp.FullName" />
                                        }
                                        else
                                        {
                                            @emp.AvatarInitials
                                        }
                                    </div>
                                    <div>
                                        <div class="emp-name">@emp.FullName</div>
                                        <div class="emp-email">@emp.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td><span class="badge badge-dept">@emp.Department</span></td>
                            <td style="color:var(--color-text-secondary);">@emp.Designation</td>
                            <td><span class="badge @typeBadge">@emp.EmploymentType</span></td>
                            <td style="color:var(--color-text-secondary);white-space:nowrap;">@emp.DateOfJoining.ToString("dd MMM yyyy")</td>
                            <td style="color:var(--color-text-secondary);font-family:var(--font-mono);font-size:var(--text-xs);">@emp.PhoneNumber</td>
                            <td>
                                <div class="action-cell">
                                    <a asp-controller="Employee" asp-action="Details" asp-route-id="@emp.Id" class="btn-icon" title="View">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                    </a>
                                    <a asp-controller="Employee" asp-action="Edit" asp-route-id="@emp.Id" class="btn-icon" title="Edit">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                    </a>
                                    <a asp-controller="Employee" asp-action="Delete" asp-route-id="@emp.Id" class="btn-icon btn-icon-danger" title="Delete">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                                    </a>
                                    <a asp-controller="Employee" asp-action="DownloadPdf" asp-route-id="@emp.Id" class="btn-icon" title="Download PDF" target="_blank">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="9" style="text-align:center;padding:var(--space-12);color:var(--color-text-muted);">
                        <div style="font-size:var(--text-lg);font-weight:600;margin-bottom:var(--space-2);">No employees found</div>
                        <div style="font-size:var(--text-sm);">Try adjusting your filters or <a asp-action="Create" style="color:var(--color-primary);">add a new employee</a>.</div>
                    </td></tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.Count > 0)
    {
        <div class="results-summary">Showing @Model.Count employees</div>
    }
</div>
