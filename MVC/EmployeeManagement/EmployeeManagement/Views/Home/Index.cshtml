@{
    ViewData["Title"] = "Dashboard";
    var deptCounts = (Dictionary<string, int>)ViewBag.DepartmentCounts;
    var empTypeCounts = (Dictionary<string, int>)ViewBag.EmploymentTypeCounts;
    var recentJoiners = (List<EmployeeManagement.Models.Employee>)ViewBag.RecentJoiners;
    int total = (int)ViewBag.TotalEmployees;
    int newMonth = (int)ViewBag.NewThisMonth;
    int deptCount = deptCounts?.Count ?? 0;
    int fullTime = (int)ViewBag.FullTimeCount;
    int contract = (int)ViewBag.ContractCount;
    int intern = (int)ViewBag.InternCount;
    int partTime = (int)ViewBag.PartTimeCount;
    int maxDept = deptCounts?.Values.Max() ?? 1;
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Dashboard</h1>
        <p>@DateTime.Today.ToString("dddd, MMMM d, yyyy")</p>
    </div>
</div>

<!-- Stats Row -->
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-card-top">
            <div>
                <div class="stat-number">@total</div>
                <div class="stat-label">Total Employees</div>
            </div>
            <div class="stat-icon navy">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
        </div>
        <div><span class="stat-badge up">↑ Active: @ViewBag.ActiveCount</span></div>
    </div>
    <div class="stat-card">
        <div class="stat-card-top">
            <div>
                <div class="stat-number">@newMonth</div>
                <div class="stat-label">New This Month</div>
            </div>
            <div class="stat-icon green">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
            </div>
        </div>
        <div><span class="stat-badge up">↑ Growing team</span></div>
    </div>
    <div class="stat-card">
        <div class="stat-card-top">
            <div>
                <div class="stat-number">@fullTime</div>
                <div class="stat-label">Full-Time vs Contract</div>
            </div>
            <div class="stat-icon info">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            </div>
        </div>
        @{
            int ftpct = total > 0 ? (int)(fullTime * 100.0 / total) : 0;
            int cpct  = total > 0 ? (int)(contract * 100.0 / total) : 0;
        }
        <div style="margin-top:4px;">
            <div style="height:6px;background:var(--color-bg-alt);border-radius:20px;overflow:hidden;margin-bottom:4px;">
                <div style="width:@ftpct%;height:100%;background:var(--color-primary);border-radius:20px;"></div>
            </div>
            <div style="font-size:var(--text-xs);color:var(--color-text-muted);">FT @ftpct% &nbsp;·&nbsp; Contract @cpct%</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-card-top">
            <div>
                <div class="stat-number">@deptCount</div>
                <div class="stat-label">Departments</div>
            </div>
            <div class="stat-icon amber">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            </div>
        </div>
        <div><span class="stat-badge up">Across @deptCount divisions</span></div>
    </div>
</div>

<!-- Charts + Charts Row -->
<div class="dashboard-grid">
    <!-- Department bar chart -->
    <div class="chart-card">
        <div class="chart-title">Headcount by Department</div>
        <div class="dept-bars">
            @if (deptCounts != null)
            {
                foreach (var dept in deptCounts.OrderByDescending(d => d.Value))
                {
                    int pct = maxDept > 0 ? (int)(dept.Value * 100.0 / maxDept) : 0;
                    <div class="dept-bar-row">
                        <div class="dept-bar-label" title="@dept.Key">@dept.Key</div>
                        <div class="dept-bar-track">
                            <div class="dept-bar-fill" style="width:@pct%"></div>
                        </div>
                        <div class="dept-bar-count">@dept.Value</div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- Donut chart -->
    <div class="chart-card" style="display:flex;flex-direction:column;">
        <div class="chart-title">Employment Mix</div>
        <div style="flex:1;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:var(--space-5);">
            <div style="position:relative;width:160px;height:160px;">
                <canvas id="donutChart" width="160" height="160"></canvas>
            </div>
            <div style="display:flex;flex-wrap:wrap;gap:var(--space-3);justify-content:center;">
                <div style="display:flex;align-items:center;gap:6px;font-size:var(--text-xs);"><span style="width:10px;height:10px;border-radius:50%;background:#1B3A6B;display:inline-block;"></span> Full-Time (@fullTime)</div>
                <div style="display:flex;align-items:center;gap:6px;font-size:var(--text-xs);"><span style="width:10px;height:10px;border-radius:50%;background:#D97706;display:inline-block;"></span> Contract (@contract)</div>
                <div style="display:flex;align-items:center;gap:6px;font-size:var(--text-xs);"><span style="width:10px;height:10px;border-radius:50%;background:#0284C7;display:inline-block;"></span> Intern (@intern)</div>
                <div style="display:flex;align-items:center;gap:6px;font-size:var(--text-xs);"><span style="width:10px;height:10px;border-radius:50%;background:#7C3AED;display:inline-block;"></span> Part-Time (@partTime)</div>
            </div>
        </div>
    </div>
</div>

<!-- Recent Joiners -->
<div class="card mb-5">
    <div class="card-header" style="display:flex;justify-content:space-between;align-items:center;">
        <span>Recent Joiners</span>
        <a asp-controller="Employee" asp-action="Index" class="btn-secondary" style="font-size:var(--text-xs);padding:5px 14px;">View All →</a>
    </div>
    <div class="table-responsive">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Employee</th>
                    <th>Department</th>
                    <th>Designation</th>
                    <th>Joining Date</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @if (recentJoiners != null && recentJoiners.Any())
                {
                    foreach (var emp in recentJoiners)
                    {
                        <tr onclick="window.location='@Url.Action("Details","Employee",new{id=emp.Id})'" style="cursor:pointer;">
                            <td>
                                <div class="emp-cell">
                                    <div class="emp-avatar" style="background:@GetAvatarColor(emp.Id)">
                                        @if (!string.IsNullOrEmpty(emp.ProfilePhotoPath))
                                        {
                                            <img src="@emp.ProfilePhotoPath" alt="@emp.FullName" />
                                        }
                                        else
                                        {
                                            @emp.AvatarInitials
                                        }
                                    </div>
                                    <div>
                                        <div class="emp-name">@emp.FullName</div>
                                        <div class="emp-email">@emp.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td><span class="badge badge-dept">@emp.Department</span></td>
                            <td style="color:var(--color-text-secondary);">@emp.Designation</td>
                            <td style="color:var(--color-text-secondary);">@emp.DateOfJoining.ToString("dd MMM yyyy")</td>
                            <td>
                                <span class="badge @(emp.IsActive ? "badge-active" : "badge-inactive")">
                                    @(emp.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="5" style="text-align:center;color:var(--color-text-muted);padding:var(--space-8);">No employees yet.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Quick Actions -->
<div class="quick-actions">
    <a asp-controller="Employee" asp-action="Create" class="quick-action-card primary-action">
        <div class="qa-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
        </div>
        <div class="qa-title">Add New Employee</div>
        <div class="qa-desc">Register a new team member</div>
    </a>
    <a asp-controller="Employee" asp-action="ExportExcel" class="quick-action-card">
        <div class="qa-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        </div>
        <div class="qa-title">Download All Records</div>
        <div class="qa-desc">Export all employee data to Excel</div>
    </a>
    <a asp-controller="Employee" asp-action="Index" class="quick-action-card">
        <div class="qa-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </div>
        <div class="qa-title">Search Directory</div>
        <div class="qa-desc">Find and manage employees</div>
    </a>
</div>

@section Scripts {
<script>
    // Donut chart
    document.addEventListener('DOMContentLoaded', function () {
        const ctx = document.getElementById('donutChart')?.getContext('2d');
        if (!ctx) return;
        new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: ['Full-Time', 'Contract', 'Intern', 'Part-Time'],
                datasets: [{
                    data: [@fullTime, @contract, @intern, @partTime],
                    backgroundColor: ['#1B3A6B', '#D97706', '#0284C7', '#7C3AED'],
                    borderWidth: 0,
                    hoverOffset: 6
                }]
            },
            options: {
                cutout: '70%',
                plugins: { legend: { display: false }, tooltip: { callbacks: { label: ctx => ` ${ctx.label}: ${ctx.raw}` } } }
            }
        });
    });
</script>
}

@functions {
    string GetAvatarColor(int id) {
        var colors = new[] { "#1B3A6B","#0EA271","#D97706","#0284C7","#7C3AED","#DC2626","#059669","#2452A0" };
        return colors[id % colors.Length];
    }
}
